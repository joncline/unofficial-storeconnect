<section class="SC-ContentBlock SC-StoSplit" id="SC-ContentBlock-{{ content_block.identifier }}" data-cb="{{ content_block.identifier }}">
  <div class="SC-StoSplit_wrapper">
    <div class="SC-StoSplit_image">
      {%- if content_block.image != blank %}
        <img loading="lazy" src="{{ content_block.image.url }}" alt="{{ content_block.title | escape }}" />
      {%- else %}
        <svg class="SC-Placeholder" width="400" viewBox="0 0 600 600"><rect width="100%" height="100%" fill="#efefef"></rect></svg>
      {%- endif %}
    </div>
    <div class="SC-StoSplit_text">
      {%- unless content_block.title == blank %}
        <h2 class="SC-StoSplit_title">{{ content_block.title }}</h2>
      {%- endunless %}
      {%- unless content_block.subtitle == blank %}
        <p class="SC-StoSplit_subtitle">{{ content_block.subtitle }}</p>
      {%- endunless %}
      {%- unless content_block.content == blank %}
        <div class="SC-StoSplit_body sc-rich-text">{{ content_block.content }}</div>
      {%- endunless %}
      {%- unless content_block.link_label == blank or content_block.link_target == blank %}
        <a href="{{ content_block.link_target }}" class="SC-Button">{{ content_block.link_label }}</a>
      {%- endunless %}
    </div>
  </div>
</section>