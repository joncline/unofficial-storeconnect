<section class="SC-ContentBlock SC-StoPromo" id="SC-ContentBlock-{{ content_block.identifier }}" data-cb="{{ content_block.identifier }}">
  {%- if content_block.image != blank %}
    <div class="SC-StoPromo_background" style="background-image: url('{{ content_block.image.url }}');">
  {%- else %}
    <div class="SC-StoPromo_background SC-StoPromo_background--placeholder">
  {%- endif %}
      <div class="SC-StoPromo_overlay"></div>
      <div class="SC-StoPromo_content">
        {%- unless content_block.subtitle == blank %}
          <span class="SC-StoPromo_label">{{ content_block.subtitle }}</span>
        {%- endunless %}
        {%- unless content_block.title == blank %}
          <h2 class="SC-StoPromo_title">{{ content_block.title }}</h2>
        {%- endunless %}
        {%- unless content_block.content == blank %}
          <div class="SC-StoPromo_body sc-rich-text">{{ content_block.content }}</div>
        {%- endunless %}
        {%- unless content_block.link_label == blank or content_block.link_target == blank %}
          <a href="{{ content_block.link_target }}" class="SC-Button">{{ content_block.link_label }}</a>
        {%- endunless %}
      </div>
    </div>
</section>