<section class="SC-ContentBlock SC-StoNewsletter" id="SC-ContentBlock-{{ content_block.identifier }}" data-cb="{{ content_block.identifier }}">
  <div class="SC-StoNewsletter_wrapper">
    {%- unless content_block.title == blank %}
      <h2 class="SC-StoNewsletter_title">{{ content_block.title }}</h2>
    {%- else %}
      <h2 class="SC-StoNewsletter_title">Stay on the Trail</h2>
    {%- endunless %}
    {%- unless content_block.subtitle == blank %}
      <p class="SC-StoNewsletter_subtitle">{{ content_block.subtitle }}</p>
    {%- else %}
      <p class="SC-StoNewsletter_subtitle">Sign up for the latest gear drops, trail tips, and exclusive offers.</p>
    {%- endunless %}
    <form class="SC-StoNewsletter_form" onsubmit="event.preventDefault();">
      <input type="email" class="SC-StoNewsletter_input" placeholder="Enter your email" />
      <button type="submit" class="SC-Button SC-StoNewsletter_button">Subscribe</button>
    </form>
    <div class="SC-StoNewsletter_social">
      <a href="#" class="SC-StoNewsletter_socialLink" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
      <a href="#" class="SC-StoNewsletter_socialLink" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
      <a href="#" class="SC-StoNewsletter_socialLink" aria-label="Twitter"><i class="fab fa-twitter"></i></a>
      <a href="#" class="SC-StoNewsletter_socialLink" aria-label="Pinterest"><i class="fab fa-pinterest"></i></a>
    </div>
  </div>
</section>